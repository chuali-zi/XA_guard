{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xa-guard.local/schema/csab-corpus-manifest.schema.json",
  "title": "XA-Guard auditable CSAB corpus manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "corpus_id", "version", "taxonomy_version", "normalization_version", "independent_evaluator_attestation", "claim_scope", "refusal_taxonomy", "sources", "artifacts", "commitment_sha256"],
  "properties": {
    "schema_version": {"const": "xa-guard-csab-corpus/v1"},
    "corpus_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "taxonomy_version": {"type": "string", "minLength": 1},
    "normalization_version": {"const": "xa-guard-payload-normalization/v1"},
    "independent_evaluator_attestation": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["evaluator", "issued_at", "statement", "path", "sha256"],
          "properties": {
            "evaluator": {"type": "string", "minLength": 1},
            "issued_at": {"type": "string", "format": "date-time"},
            "statement": {"type": "string", "minLength": 1},
            "path": {"type": "string", "minLength": 1},
            "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
          }
        }
      ]
    },
    "claim_scope": {"type": "string", "minLength": 1},
    "refusal_taxonomy": {
      "type": "array",
      "maxItems": 17,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category_id", "label", "standard_clause", "source_url", "alignment_reviewed"],
        "properties": {
          "category_id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "standard_clause": {"type": "string", "minLength": 1},
          "source_url": {"type": "string", "format": "uri"},
          "alignment_reviewed": {"type": "boolean"}
        }
      }
    },
    "sources": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["source_id", "title", "url", "version", "retrieved_at", "license_id", "license_url", "redistribution", "artifact_sha256"],
        "properties": {
          "source_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri"},
          "version": {"type": "string", "minLength": 1},
          "retrieved_at": {"type": "string", "format": "date"},
          "license_id": {"type": "string", "minLength": 1},
          "license_url": {"type": "string", "format": "uri"},
          "license_file": {"type": "string", "minLength": 1},
          "license_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "redistribution": {"enum": ["allowed", "external_only"]},
          "artifact_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    },
    "artifacts": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["cohort", "split", "path", "sha256", "case_count"],
        "properties": {
          "cohort": {"enum": ["refusal", "non_refusal"]},
          "split": {"enum": ["development", "calibration", "holdout"]},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "case_count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "selection": {"type": "object"},
    "commitment_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}

