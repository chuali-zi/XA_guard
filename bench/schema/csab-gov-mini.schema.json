{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xa-guard.local/schema/csab-gov-mini.schema.json",
  "title": "CSAB-Gov-mini benchmark suite",
  "description": "Schema for bench/cases/csab-gov-mini-seed.yaml. Validates each case carries case_kind + source attribution so the asset is auditable as YAML grows.",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "cases"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["name", "total", "version", "dimensions", "sources"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "total": {"type": "integer", "minimum": 1},
        "version": {"type": "string", "minLength": 1},
        "dimensions": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "note": {"type": "string"}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "dimension": {
      "type": "string",
      "enum": [
        "execution_safety",
        "data_safety",
        "content_safety",
        "supply_chain",
        "compliance",
        "interpretability",
        "traceability"
      ]
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "warn", "deny", "require_approval"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "caseKind": {
      "type": "string",
      "enum": ["attack_case", "benign_control", "assurance_check", "exploratory_finding"]
    },
    "sourceDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standard"],
      "properties": {
        "standard": {"type": "string", "minLength": 1},
        "clause": {"type": "string"},
        "title": {"type": "string"}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "dimension",
        "attack_type",
        "case_kind",
        "input_payload",
        "expected_decision",
        "severity",
        "source_documents",
        "note"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*-[0-9]{3,4}$"
        },
        "dimension": {"$ref": "#/$defs/dimension"},
        "attack_type": {"type": "string", "minLength": 1},
        "case_kind": {"$ref": "#/$defs/caseKind"},
        "input_payload": {
          "type": "object",
          "required": ["tool_name"],
          "properties": {
            "tool_name": {"type": "string", "minLength": 1},
            "arguments": {"type": "object"},
            "user_role": {"type": "string"},
            "input_sources": {
              "type": "array",
              "items": {"type": "string"}
            },
            "session_history": {
              "type": "array",
              "items": {"type": "object"}
            },
            "message": {"type": "string"}
          }
        },
        "expected_decision": {"$ref": "#/$defs/decision"},
        "expected_taint": {
          "type": "string",
          "enum": ["PUBLIC", "INTERNAL", "CONFIDENTIAL"]
        },
        "policy_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "source_documents": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/sourceDocument"}
        },
        "severity": {"$ref": "#/$defs/severity"},
        "note": {"type": "string"},
        "fingerprint": {"type": "string"}
      }
    }
  }
}
