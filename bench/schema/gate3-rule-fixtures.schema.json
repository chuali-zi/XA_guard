{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xa-guard.local/schema/gate3-rule-fixtures.schema.json",
  "title": "Gate3 rule positive and negative fixtures",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "fixtures"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "version", "policy_file"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "policy_file": {"type": "string", "minLength": 1},
        "note": {"type": "string"}
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/ruleFixture"}
    }
  },
  "$defs": {
    "decision": {
      "type": "string",
      "enum": ["allow", "warn", "deny", "require_approval"]
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "input_payload", "expected_hit"],
      "properties": {
        "case_id": {"type": "string", "minLength": 1},
        "input_payload": {
          "type": "object",
          "required": ["tool_name"],
          "additionalProperties": true,
          "properties": {
            "tool_name": {"type": "string", "minLength": 1},
            "arguments": {"type": "object"},
            "user_role": {"type": "string"},
            "risk_level": {"type": "string", "enum": ["green", "yellow", "red"]},
            "taint": {"type": "string", "enum": ["PUBLIC", "INTERNAL", "CONFIDENTIAL"]},
            "input_sources": {
              "type": "array",
              "items": {"type": "string", "enum": ["user", "web", "document", "rag", "memory", "tool_result"]}
            },
            "session_history": {
              "type": "array",
              "items": {"type": "object"}
            }
          }
        },
        "expected_hit": {"type": "boolean"},
        "expected_decision": {"$ref": "#/$defs/decision"},
        "note": {"type": "string"}
      }
    },
    "ruleFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "positive", "negative"],
      "properties": {
        "rule_id": {"type": "string", "minLength": 1},
        "positive": {"$ref": "#/$defs/case"},
        "negative": {"$ref": "#/$defs/case"}
      }
    }
  }
}
