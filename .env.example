# XA-Guard business API adapter local configuration.
# Copy to .env on this machine only. Never commit real secrets.

BUSINESS_API_BASE_URL=https://business-api.example.com
BUSINESS_API_KEY=replace-with-local-api-key
BUSINESS_API_TIMEOUT_SECONDS=10

# Tests and local mocks may use http://127.0.0.1 only when this is true.
BUSINESS_API_ALLOW_INSECURE_LOCAL=false
