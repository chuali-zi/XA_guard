{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xa-guard.example/schemas/xa-guard-evidence-v1.schema.json",
  "title": "XA-Guard Identity and Undo sealed evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "run",
    "source",
    "images",
    "tools",
    "artifacts",
    "chains",
    "cross_links",
    "acceptance",
    "signature"
  ],
  "$defs": {
    "nonEmpty": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\u0000]+$"
    },
    "chain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "algorithm", "records"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "algorithm": { "enum": ["sha256", "sm3"] },
        "records": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "properties": {
    "schema": {
      "const": "xa-guard-evidence/v1"
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "started_at", "completed_at"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmpty" },
        "mode": { "$ref": "#/$defs/nonEmpty" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision", "dirty"],
      "properties": {
        "repository": { "$ref": "#/$defs/nonEmpty" },
        "revision": { "$ref": "#/$defs/nonEmpty" },
        "dirty": { "type": "boolean" }
      }
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "digest"],
        "properties": {
          "name": { "$ref": "#/$defs/nonEmpty" },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": { "$ref": "#/$defs/nonEmpty" },
          "version": { "$ref": "#/$defs/nonEmpty" }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "bytes", "sha256"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "chains": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate6", "effect"],
      "properties": {
        "gate6": { "$ref": "#/$defs/chain" },
        "effect": {
          "allOf": [
            { "$ref": "#/$defs/chain" },
            {
              "type": "object",
              "properties": {
                "algorithm": { "const": "sha256" }
              }
            }
          ]
        }
      }
    },
    "cross_links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "agent_id",
        "effect_id",
        "original_trace_id",
        "compensation_trace_id",
        "requester_sub",
        "approver_sub",
        "business_effect_id",
        "business_artifact",
        "assignment_artifact",
        "assignment_snapshot_sha256",
        "assignment_id",
        "assignment_version"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/nonEmpty" },
        "agent_id": { "$ref": "#/$defs/nonEmpty" },
        "effect_id": { "$ref": "#/$defs/nonEmpty" },
        "original_trace_id": { "$ref": "#/$defs/nonEmpty" },
        "compensation_trace_id": { "$ref": "#/$defs/nonEmpty" },
        "requester_sub": { "$ref": "#/$defs/nonEmpty" },
        "approver_sub": { "$ref": "#/$defs/nonEmpty" },
        "business_effect_id": { "$ref": "#/$defs/nonEmpty" },
        "business_artifact": { "$ref": "#/$defs/relativePath" },
        "assignment_artifact": { "$ref": "#/$defs/relativePath" },
        "assignment_snapshot_sha256": { "$ref": "#/$defs/sha256" },
        "assignment_id": { "$ref": "#/$defs/nonEmpty" },
        "assignment_version": { "type": "integer", "minimum": 1 }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assertions", "boundaries"],
      "properties": {
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "statement", "passed", "evidence"],
            "properties": {
              "id": { "$ref": "#/$defs/nonEmpty" },
              "statement": { "$ref": "#/$defs/nonEmpty" },
              "passed": { "type": "boolean" },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/relativePath" }
              }
            }
          }
        },
        "boundaries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "statement"],
            "properties": {
              "id": { "$ref": "#/$defs/nonEmpty" },
              "statement": { "$ref": "#/$defs/nonEmpty" }
            }
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "public_key", "value"],
      "properties": {
        "algorithm": { "const": "SM2-with-SM3" },
        "key_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{16}$"
        },
        "public_key": {
          "type": "string",
          "pattern": "^[0-9a-f]{128}$"
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{128}$"
        }
      }
    }
  }
}
