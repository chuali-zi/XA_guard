# Word/Office lock & temp files
~$*

# Claude Code local settings
.claude/

# OS junk
Thumbs.db
.DS_Store

# Local secrets
.env
.env.*
!.env.example

# Node
node_modules/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.pytest_cache/
.pytest_tmp/
pytest_tmp_*/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Runtime / audit output (保留 .log/ 模块工作日志，不提交 logs/)
logs/
.runtime/reference/
.runtime/kind-ha/
.runtime/evidence/
open-agent-range/.runtime/delivery-v2-canonical-*/
open-agent-range/.runtime/my-try-ab-offline/
open-agent-range/auto-redteam/.state/
open-agent-range/auto-redteam/conductor/opencode-maintained.yaml
*.jsonl
!bench/external/fixtures/*.jsonl
!bench/.log/.gitkeep
!**/.log/worklog.md
!enterprise-agent-range/reports/run-p0-null-verify/*.jsonl
!enterprise-agent-range/reports/run-p1-null-verify/*.jsonl
# Committed evidence artifacts (audit samples, benchmark results) under docs/evidence/
!docs/evidence/**
# but never commit private key material even inside evidence
docs/evidence/**/*.key
docs/evidence/**/tsa-demo.key

# Local tool binaries downloaded for verification.
tools/opa/opa.exe

# Local opencode run config (per-machine MCP/model wiring; canonical smoke config is configs/opencode.l3-smoke.json)
/opencode.json
/opencode.jsonc

# Local acceptance config (contains machine-specific paths; canonical example is configs/r2-r3-acceptance.example.json)
*.local.json
